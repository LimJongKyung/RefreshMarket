[Unit]
Description=RefreshMarket Spring Boot application
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=opc
WorkingDirectory=/opt/refreshmarket/app
EnvironmentFile=/opt/refreshmarket/refreshmarket.env
ExecStart=/opt/refreshmarket/java/bin/java -Xms96m -Xmx256m -XX:+UseSerialGC -jar /opt/refreshmarket/app/devProject-0.0.1-SNAPSHOT.jar
SuccessExitStatus=143
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
